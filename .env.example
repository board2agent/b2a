# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens (classic) or https://github.com/settings/personal-access-tokens (fine-grained)
# Classic PAT: needs "repo" scope
# Fine-grained PAT: needs Issues (Read/Write) + Contents (Read/Write)
GITHUB_TOKEN=ghp_your_personal_access_token

# Target repository
GITHUB_OWNER=your-org-or-username
GITHUB_REPO=your-repo-name

# Board polling interval in milliseconds
POLL_INTERVAL_MS=5000
